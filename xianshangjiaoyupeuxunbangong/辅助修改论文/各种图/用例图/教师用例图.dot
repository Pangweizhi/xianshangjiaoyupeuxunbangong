  c6 [label="考试与题库管理", shape=ellipse, style="filled", fillcolor="white"];
  c7 [label="成绩统计", shape=ellipse, style="filled", fillcolor="white"];
  c8 [label="AI 题目生成", shape=ellipse, style="filled", fillcolor="white"];

  actor -> c1;
