digraph G {
  graph [charset="UTF-8", bgcolor="white", labelloc="t", label="教师用例图", fontname="Microsoft YaHei", fontsize=22, rankdir="LR", splines=ortho, nodesep=0.25, ranksep=0.55, pad=0.15, margin=0.10, size="8,8!"];
