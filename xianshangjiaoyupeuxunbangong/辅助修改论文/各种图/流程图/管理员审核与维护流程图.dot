digraph G {
  graph [
    charset="UTF-8",
    bgcolor="white",
    fontname="Microsoft YaHei",
    fontsize=22,
    rankdir="TB",
    splines=ortho,
    nodesep=0.38,
    ranksep=0.46,
    pad=0.18,
    margin=0.10,
    size="7.2,7.2!",
    ratio=fill
  ];

  node [
    fontname="Microsoft YaHei",
    fontsize=11,
    shape=box,
    style="rounded,filled",
    fillcolor="white",
    color="#444444",
    penwidth=1.25,
    width=1.75,
    height=0.45,
    fixedsize=false,
    margin="0.10,0.07"
  ];

  edge [
    fontname="Microsoft YaHei",
    fontsize=9,
    color="#333333",
    penwidth=1.0,
    arrowsize=0.65
  ];

  start [
    label="开始",
    shape=ellipse,
    fillcolor="#f7f7f7",
    width=1.15,
    height=0.42
  ];

  login [label="管理员登录"];

  check [
    label="管理员\n是否存在",
    shape=diamond,
    style="filled",
    fillcolor="white",
    width=1.55,
    height=0.85,
    margin="0.04,0.04"
  ];

  home [label="后台管理系统"];

  auditCourse [
    label="审核课程",
    group="audit_col"
  ];

  auditChapter [
    label="审核章节",
    group="audit_col"
  ];

  auditResource [
    label="审核资源",
    group="audit_col"
  ];

  user [
    label="用户 / 教师管理",
    group="maintain_col"
  ];

  dict [
    label="字典 / 配置维护",
    group="maintain_col"
  ];

  notice [
    label="公告与新闻维护",
    group="maintain_col"
  ];

  exam [
    label="考试 / 题库维护",
    group="maintain_col"
  ];

  ai [
    label="AI 问题配置",
    group="maintain_col"
  ];

  exit [
    label="退出系统",
    shape=ellipse,
    fillcolor="#f7f7f7",
    width=1.15,
    height=0.42
  ];

  {
    rank=same;
    auditCourse;
    user;
  }

  {
    rank=same;
    auditChapter;
    dict;
  }

  {
    rank=same;
    auditResource;
    notice;
  }

  start -> login;
  login -> check;

  check -> home [
    xlabel="存在",
    labeldistance=1.15,
    labelangle=-18
  ];

  check -> login [
    xlabel="不存在",
    constraint=false,
    labeldistance=1.45,
    labelangle=24
  ];

  home -> auditCourse;
  home -> user;

  auditCourse -> auditChapter;
  auditChapter -> auditResource;

  user -> dict;
  dict -> notice;
  notice -> exam;
  exam -> ai;

  auditResource -> exit;
  ai -> exit;
}