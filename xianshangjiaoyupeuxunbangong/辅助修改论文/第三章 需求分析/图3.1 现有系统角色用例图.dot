digraph G {
  graph [charset="UTF-8", bgcolor="white", labelloc="t", fontname="Microsoft YaHei", fontsize=22, rankdir="LR", splines=line, nodesep=0.35, ranksep=0.70, pad=0.2, margin=0.15];
  node [fontname="Microsoft YaHei", fontsize=12, color="#444444", penwidth=1.2];
  edge [fontname="Microsoft YaHei", fontsize=9, color="#666666", penwidth=1.0, arrowsize=0.7];

  actor1 [label="管理员", shape=box, style="rounded,filled", fillcolor="#FFFFFF"];
  actor2 [label="教师", shape=box, style="rounded,filled", fillcolor="#FFFFFF"];
  actor3 [label="学生", shape=box, style="rounded,filled", fillcolor="#FFFFFF"];
  uc1 [label="用户与权限管理", shape=ellipse, style="filled", fillcolor="#FFFFFF"];
  uc2 [label="课程与资源维护", shape=ellipse, style="filled", fillcolor="#FFFFFF"];
  uc3 [label="选课与课程学习", shape=ellipse, style="filled", fillcolor="#FFFFFF"];
  uc4 [label="作业与考试管理", shape=ellipse, style="filled", fillcolor="#FFFFFF"];
  uc5 [label="成绩统计与公告发布", shape=ellipse, style="filled", fillcolor="#FFFFFF"];
  uc6 [label="AI 问答与题库辅助", shape=ellipse, style="filled", fillcolor="#FFFFFF"];

  actor1 -> uc1;
  actor1 -> uc5;
  actor1 -> uc6;
  actor2 -> uc2;
  actor2 -> uc4;
  actor2 -> uc6;
  actor3 -> uc3;
  actor3 -> uc4;
  actor3 -> uc6;
}