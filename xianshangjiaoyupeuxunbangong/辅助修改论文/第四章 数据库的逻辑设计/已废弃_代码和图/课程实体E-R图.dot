  a6 [label="开始时间", shape=ellipse, style="filled", fillcolor="#ffffff"];
  entity -> a6;
  a7 [label="结束时间", shape=ellipse, style="filled", fillcolor="#ffffff"];
  entity -> a7;
  a8 [label="课程学分", shape=ellipse, style="filled", fillcolor="#ffffff"];
  entity -> a8;
  a9 [label="审核状态", shape=ellipse, style="filled", fillcolor="#ffffff"];
